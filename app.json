{
  "expo": {
    "name": "Tech Times",
    "slug": "tech-times",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/images/e941e17d-7723-49a6-b54a-ae47846098d7.jpeg",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/4f12d49b-2be5-47bf-859e-e05eaefa35aa.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "icon": "./assets/images/e941e17d-7723-49a6-b54a-ae47846098d7.jpeg",
      "supportsTablet": true,
      "bundleIdentifier": "com.buxrug.techtime",
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.com.buxrug.techtime"
        ]
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSFaceIDUsageDescription": "TechTimes uses Face ID to securely unlock the app and protect your job data.",
        "UIBackgroundModes": [
          "fetch",
          "remote-notification",
          "processing"
        ],
        "BGTaskSchedulerPermittedIdentifiers": [
          "com.buxrug.techtime.background-processing",
          "com.buxrug.techtime.background-fetch"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/4f12d49b-2be5-47bf-859e-e05eaefa35aa.png",
        "backgroundColor": "#ff6b35"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.buxrug.techtime",
      "permissions": [
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "POST_NOTIFICATIONS",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECEIVE_BOOT_COMPLETED",
        "WAKE_LOCK",
        "FOREGROUND_SERVICE",
        "SCHEDULE_EXACT_ALARM",
        "VIBRATE"
      ],
      "versionCode": 5
    },
    "web": {
      "favicon": "./assets/images/4f12d49b-2be5-47bf-859e-e05eaefa35aa.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      "expo-web-browser",
      [
        "@bacons/apple-targets",
        {
          "targets": {
            "widget": {
              "type": "widget",
              "name": "DayProgressWidget",
              "deploymentTarget": "16.0",
              "bundleIdentifier": "com.buxrug.techtime.widget"
            }
          }
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "TechTimes uses Face ID to securely unlock the app and protect your job data."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/4f12d49b-2be5-47bf-859e-e05eaefa35aa.png",
          "color": "#ff6b35",
          "sounds": [],
          "mode": "production"
        }
      ]
    ],
    "scheme": "techtimes",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "backendUrl": "https://2h3sxpwj9zcmabbejmjer7nhf22mhmfu.app.specular.dev"
    }
  },
  "scheme": "Tech Times"
}